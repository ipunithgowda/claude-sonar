# Copy this to ~/.claude/hooks/.env and chmod 600 it.
# Get a free key at https://console.groq.com/keys
# Free tier: 30 requests/minute, plenty for a solo dev.
GROQ_API_KEY=gsk_replace_me_with_your_real_key

# How AXE should address you. One of: sir | mam | neutral
# (Uses "mam" — the British short form — because en-GB-RyanNeural swallows "ma'am".)
# - sir      → "Build successful for Project X, sir."
# - mam      → "Build successful for Project X, mam."
# - neutral  → "Build successful for Project X." (no honorific)
AXE_ADDRESS=sir
